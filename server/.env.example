# ─────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/quickkart?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────
# JWT — MUST be separate random strings of at least 32 characters each.
# Using separate secrets prevents a stolen refresh token from being used
# to forge a valid access token.
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# Run twice — use a DIFFERENT value for each variable!
# ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=your_refresh_token_secret_different_from_access_secret

# ─────────────────────────────────────────────────────
# Google OAuth
# Get from: https://console.cloud.google.com/
# ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ─────────────────────────────────────────────────────
# Frontend URLs (used for CORS — no trailing slash)
# ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
