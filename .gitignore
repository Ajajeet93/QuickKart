# QuickKart root .gitignore

# ── Environment files (NEVER commit) ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.prod

# ── Node.js ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── Build outputs ─────────────────────────────────────────────────────────
dist/
build/

# ── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log
server/logs/

# ── OS files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────
scratch/
*.pid

# ── Security ──────────────────────────────────────────────────────────────
*.pem
