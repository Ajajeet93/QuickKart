{
  "name": "quickkart",
  "version": "1.0.0",
  "description": "QuickKart MERN E-Commerce Platform - INT377 DevOps Project",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "lint:server": "cd server && eslint . --ext .js",
    "lint:client": "cd client && eslint . --ext .js,.jsx",
    "lint:admin": "cd admin && eslint . --ext .js,.jsx",
    "lint": "npm run lint:server && npm run lint:client && npm run lint:admin",
    "audit:server": "cd server && npm audit --audit-level=high",
    "audit:client": "cd client && npm audit --audit-level=high",
    "audit:admin": "cd admin && npm audit --audit-level=high",
    "audit": "npm run audit:server && npm run audit:client && npm run audit:admin",
    "docker:build": "docker compose -f devops/docker-compose.yml build",
    "docker:up": "docker compose -f devops/docker-compose.yml up --build",
    "docker:down": "docker compose -f devops/docker-compose.yml down -v",
    "k8s:apply": "kubectl apply -f devops/k8s/",
    "k8s:delete": "kubectl delete -f devops/k8s/",
    "tf:init": "cd devops/infra/terraform && terraform init",
    "tf:plan": "cd devops/infra/terraform && terraform plan",
    "tf:apply": "cd devops/infra/terraform && terraform apply",
    "tf:destroy": "cd devops/infra/terraform && terraform destroy"
  },
  "devDependencies": {
    "husky": "^9.0.11"
  },
  "author": "Ajeet Yadav <12316893@student.lpu.in>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ajajeet93/QuickKart.git"
  }
}
